# =============================================================================
# Studio – Local Development Environment
# Copy to .env and adjust as needed: cp .env.example .env
# =============================================================================

# --- Postgres ----------------------------------------------------------------
POSTGRES_DB=studio
POSTGRES_USER=studio
POSTGRES_PASSWORD=studio
POSTGRES_PORT=5432

# --- Kafka -------------------------------------------------------------------
KAFKA_PORT=9092

# --- MinIO (optional object storage) ----------------------------------------
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=studio-frames
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000

# --- App services (STUDIO_ prefix read by shared/config.py) -----------------
STUDIO_DATABASE_URL=postgresql+asyncpg://studio:studio@postgres:5432/studio
STUDIO_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
STUDIO_FRAME_STORAGE_PATH=/data/frames
STUDIO_SERVICE_NAME=local

# --- Host-side overrides (for tools running outside Docker) ------------------
# DATABASE_URL=postgresql://studio:studio@localhost:5432/studio
# KAFKA_BROKERS=localhost:29092
# OUTPUT_PATH=./data/frames
